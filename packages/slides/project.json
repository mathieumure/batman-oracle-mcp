{
  "name": "slides",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm build",
        "cwd": "{projectRoot}"
      }
    },
    "export": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm export",
        "cwd": "{projectRoot}"
      }
    }
  }
}
